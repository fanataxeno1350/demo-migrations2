@font-face{font-family:GothamHTFMedium;src:url("/content/dam/aemigrate/uploaded-folder/www-nescafe-com/font/5ef188273cbd2a4f3cfa-f879a1.ttf") format("truetype");font-display:swap;}

@font-face{font-family:NescafeSansBold;src:url("/content/dam/aemigrate/uploaded-folder/www-nescafe-com/font/a240ad40949cc29dcbbe-48132d.woff2") format("woff2");font-display:swap;}

.bg--white-accent{ background-color:rgb(250,250,250); }

.button, .labelMediumBold{ font-size:1rem;line-height:1.375rem;font-family:GothamHTFMedium,"Helvetica Neue",Helvetica,Arial,sans-serif;font-weight:400; }

@media screen and (min-width:768px) { .button, .labelMediumBold{ font-size:1.125rem;line-height:1.625rem; } }

.tooltip-signin-register{ position:absolute;height:auto;z-index:10000;padding:1.25rem 1rem 1.5rem;display:none;border-radius:0.5rem;width:calc(100% - 30px); }

@media print,screen and (min-width:48em) { .tooltip-signin-register{ padding:1.25rem 2rem 2rem;width:403px; } }

@media print,screen and (min-width:64em) { .tooltip-signin-register{ width:568px; } }

.tooltip-signin-register--title{ padding-right:1.875rem; }

.tooltip-signin-register .tooltip-signin-register--close{ position:absolute;right:1rem;top:1.25rem; }

.tooltip-signin-register .tooltip-signin-register--close-btn{ height:1.375rem;width:1.375rem;display:block;background-size:0.875rem 0.875rem;background-position:50% center; }

.tooltip-signin-register--ctas{ display:flex;gap:24px; }

@media print,screen and (min-width:64em) { .tooltip-signin-register--ctas{ gap:32px; } }

.tooltip-signin-register--arrow{ position:absolute; }

.tooltip-signin-register--container{ display:flex;-webkit-box-orient:vertical;-webkit-box-direction:normal;flex-direction:column;gap:16px; }

@media print,screen and (min-width:48em) { .tooltip-signin-register--container{ gap:24px; } }

