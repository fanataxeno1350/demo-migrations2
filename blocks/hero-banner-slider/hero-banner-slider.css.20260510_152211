.component-custom-slick-slider{ background:white; }

.component-custom-slick-slider .slider{ width:100%;margin-left:auto;margin-right:auto;margin-bottom:50px !important; }

.component-custom-slick-slider .slick-slide{ margin:auto; }

.component-custom-slick-slider .slick-slide{ -webkit-transition:all ease-in-out 0.3s;-o-transition:all ease-in-out 0.3s;transition:all ease-in-out 0.3s;opacity:0.2; }

.component-custom-slick-slider .slick-current{ opacity:1; }

.component-custom-slick-slider .banner-slider{ width:100%;position:relative; }

.component-custom-slick-slider .banner-slider .carousel-caption{ height:inherit;max-width:100%;margin-left:auto;margin-right:auto;color:white;text-align:left;position:relative;z-index:10;-webkit-transform:translateY(-100%);-ms-transform:translateY(-100%);transform:translateY(-100%); }

@media (max-width:767.98px) { .component-custom-slick-slider .banner-slider .carousel-caption{ width:calc(100% - 60px); } }

@media (min-width:768px) { .component-custom-slick-slider .banner-slider .carousel-caption{ position:absolute;top:50%;left:10%;-webkit-transform:translateY(-50%);-ms-transform:translateY(-50%);transform:translateY(-50%);width:80%; } }

@media only screen and (min-device-width:1366px) and (max-device-height:1024px) and (-webkit-min-device-pixel-ratio:2) and (orientation:landscape) { .component-custom-slick-slider .banner-slider .carousel-caption{ width:calc(100% - 345px); } }

.component-custom-slick-slider .banner-slider .carousel-caption .caption-content{ min-width:100%;position:absolute;top:50%;-webkit-transform:translateY(-50%);-ms-transform:translateY(-50%);transform:translateY(-50%); }

.component-custom-slick-slider .banner-slider .carousel-caption .caption-content p{ margin-bottom:30px; }

@media (max-width:767.98px) { .component-custom-slick-slider .banner-slider .carousel-caption .caption-content p{ margin-bottom:15px;font-size:16px;line-height:normal;letter-spacing:0.5px; } }

.component-custom-slick-slider .banner-slider .carousel-caption .text-align-center{ text-align:center; }

.component-custom-slick-slider .carousel-image{ height:100%;width:100%;background-size:cover;background-repeat:no-repeat;background-position:center;opacity:1;pointer-events:none; }

.component-custom-slick-slider .carousel-video{ height:100%;width:100%;position:relative; }

.component-custom-slick-slider .carousel-video + .carousel-image + .carousel-image{ display:none; }

.component-custom-slick-slider .carousel-video::before{ content:"";height:100%;width:100%;background:rgba(35,35,35,0.4);position:absolute;top:0;left:0;z-index:2; }

.component-custom-slick-slider .carousel-video video{ height:100%;width:100%;-o-object-fit:cover;object-fit:cover;position:absolute;top:50%;left:50%;-webkit-transform:translate(-50%,-50%);-ms-transform:translate(-50%,-50%);transform:translate(-50%,-50%);z-index:1; }

.component-custom-slick-slider h1.banner-title-medium{ font-size:clamp(2.25rem,4.25vw,5.625rem) !important;line-height:1.25 !important; }

@media (min-width:1024px) { .component-custom-slick-slider .carousel-mobile-image{ display:none; }

.component-custom-slick-slider .carousel-desktop-image{ display:block; } }

