@keyframes containerExpandUp{
  from {
    opacity: 0;
    transform: scaleY(0);
    transform-origin: bottom right;
  }
  to {
    opacity: 1;
    transform: scaleY(1);
    transform-origin: bottom right;
  }
}

@keyframes imageExpandUp{
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideDown{
  from {
    transform: translateY(-100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes slideLeft{
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(0);
  }
}

@keyframes slideRight{
  from {
    transform: translateX(-100%);
  }
  to {
    transform: translateX(0);
  }
}

