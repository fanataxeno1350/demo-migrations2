.cmp-media__wrapper--no-title{ 
  position: relative;
  overflow-x: hidden;
  width: 100vw;
 }

@media (max-width: 1024px) { .cmp-media__wrapper--no-title .video{ 
    height: 690px !important;
   }

.cmp-media__wrapper--no-title .video-container, .cmp-media__wrapper--no-title .video-poster, .cmp-media__wrapper--no-title .video-container__video{ 
    width: 100%;
    height: 690px !important;
    object-fit: cover;
    position: absolute;
   } }

@media (min-width: 1025px) { .cmp-media__wrapper--no-title .video{ 
    height: 728px !important;
   }

.cmp-media__wrapper--no-title .video-container, .cmp-media__wrapper--no-title .video-poster, .cmp-media__wrapper--no-title .video-container__video{ 
    height: 728px !important;
    width: 100%;
    object-fit: cover;
    position: absolute;
   } }

.video-poster, .video-container{ 
  width: 100%;
  height: 100%;
  position: relative;
 }

.video-poster__video, .video-container__video{ 
  width: 100%;
  aspect-ratio: 16/9;
  display: block;
  position: relative;
 }

.video-hide{ 
  display: none;
 }

.video-poster__play-button{ 
  --clickable-element-block-size: clamp(48px, calc(48px + 16 * (100vw - 375px) / 817), 64px);
  background: transparent;
  padding: 0;
  block-size: var(--clickable-element-block-size);
  position: absolute;
  inset-inline-start: 50%;
  inset-block-start: 50%;
  transform: translate(calc(var(--clickable-element-block-size) * -0.5), -50%);
  cursor: pointer;
  text-decoration: none;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-1);
  z-index: 2;
 }

.video-poster__play-button:focus-visible{ 
  border-radius: 100px;
  outline: 2px solid var(--white);
  outline-offset: 2px;
 }

.video-poster__play-button:hover .video-poster__play-button__icon{ 
  transform: translateX(0.2em);
  background: transparent;
  border-color: var(--white);
 }

.video-poster__play-button:hover .video-poster__play-button__icon::before{ 
  color: var(--white);
 }

.video-poster__play-button:focus-visible .video-poster__play-button__icon{ 
  background: transparent;
  border-color: var(--white);
 }

.video-poster__play-button:focus-visible .video-poster__play-button__icon::before{ 
  color: var(--white);
 }

.video-poster__play-button__icon{ 
  block-size: var(--clickable-element-block-size);
  inline-size: var(--clickable-element-block-size);
  background: var(--white);
  border: 2px solid var(--clickable-element-border-color, var(--clickable-element-base-border-color, var(--clickable-element-base-background-color)));
  border-radius: 50%;
  transition: all 0.2s ease-in-out;
  display: flex;
  align-items: center;
  justify-content: center;
 }

.video-poster__play-button__icon::before{ 
  font-size: 24px;
  color: #054021;
 }

.video-poster__play-button__text{ 
  font-family: var(--default-font-family);
  font-weight: var(--heading-5-font-weight);
  font-size: var(--heading-5-font-size);
  line-height: var(--heading-5-line-height);
  letter-spacing: var(--heading-5-letter-spacing);
  color: var(--white);
  padding-inline-end: var(--spacing-1);
 }

.video-container.show-controls .video-container__controls{ 
  bottom: 0;
  opacity: 1;
  pointer-events: auto;
  transition: all ease 0.13s;
 }

.video-container__controls{ 
  position: absolute;
  width: 100%;
  padding: 16px;
  color: var(--white);
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.5) 75%);
  z-index: 2;
  bottom: -15px;
  opacity: 0;
  pointer-events: none;
  transition: all ease 0.08s;
  direction: ltr;
 }

.video-container__controls__timer{ 
  position: relative;
  width: 100%;
  block-size: 32px;
  margin-bottom: 16px;
 }

.video-container__controls__timer__progress-area{ 
  width: 100%;
  height: 5px;
  cursor: pointer;
  display: flex;
  align-items: center;
 }

.video-container__controls__timer__progress-area__pointer{ 
  background: transparent;
  border: 2px solid var(--white);
  width: 16px;
  height: 16px;
  display: block;
  border-radius: 50%;
 }

.video-container__controls__timer__progress-area__progress-pending{ 
  height: 3px;
  background-color: rgba(255, 255, 255, 0.302);
  flex: 1;
 }

.video-container__controls__timer__current-time{ 
  left: 0;
 }

.video-container__controls__timer__duration{ 
  right: 0;
 }

.video-container__controls__timer__current-time, .video-container__controls__timer__duration{ 
  position: absolute;
  inset-block-end: 0;
 }

.video-container__controls__buttons{ 
  display: flex;
  align-items: center;
  gap: 8px;
 }

.video-container__controls__buttons__icon{ 
  font-size: 24px;
 }

.video-container__controls__buttons--button{ 
  background-color: var(--tertiary-base);
  color: var(--white);
  border: 2px solid var(--tertiary-base);
  border-radius: 50%;
  cursor: pointer;
  width: 48px;
  height: 48px;
 }

.video-container__controls__buttons--button:focus-visible{ 
  outline: 2px solid var(--tertiary-base);
  outline-offset: 2px;
 }

.video-container__controls__buttons--button:first-child{ 
  margin-right: auto;
 }

.video-container__controls__buttons--button:hover{ 
  background-color: var(--white);
  color: var(--tertiary-base);
 }

@keyframes upFadeIn{
  from {
    transform: scaleY(0.1);
    transform-origin: bottom;
  }
  to {
    transform: scaleY(1);
    transform-origin: bottom;
  }
}

@keyframes zoomOutScale{
  from {
    visibility: visible;
    transform: scale(0.8);
  }
  to {
    visibility: visible;
    transform: scale(1);
  }
}

@keyframes zoomOutScaleRTL{
  from {
    visibility: visible;
    transform: scale(0.8);
  }
  to {
    visibility: visible;
    transform: scale(1);
  }
}

