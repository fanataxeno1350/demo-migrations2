@keyframes cmp-search__loading-indicator-spin{0{transform:rotate(0)}
100%{transform:rotate(360deg)}
}

.fixed-top{ top:0 }

.fixed-top{ left:0;position:fixed;right:0;z-index:1030 }

.w-25{ width:25% !important }

.justify-content-end{ -webkit-box-pack:end !important;-ms-flex-pack:end !important;justify-content:flex-end !important }

.px-4{ padding-left:.75rem !important;padding-right:.75rem !important }

.px-5{ padding-left:1rem !important;padding-right:1rem !important }

.py-2{ padding-bottom:.25rem !important;padding-top:.25rem !important }

.py-3{ padding-bottom:.5rem !important;padding-top:.5rem !important }

.fw-semibold{ font-weight:600 !important }

.text-boing-primary{ --bs-text-opacity:1;color:#aa1f30 !important }

.bg-white{ --bs-bg-opacity:1;background-color:#fff !important }

.rounded-4{ border-radius:var(--bs-border-radius-xl) !important }

@font-face{font-family:swiper-icons;font-style:normal;font-weight:400;src:url("data:application/font-woff;charset=utf-8;base64,") format("woff")}

@keyframes swiper-preloader-spin{0{-webkit-transform:rotate(0);transform:rotate(0)}
to{-webkit-transform:rotate(1turn);transform:rotate(1turn)}
}

@keyframes spinner-boing{to{-webkit-transform:rotate(1turn);transform:rotate(1turn)}
}

.header{ -webkit-box-shadow:.125rem .125rem .9375rem 0 rgba(0,0,0,.071);box-shadow:.125rem .125rem .9375rem 0 rgba(0,0,0,.071);max-height:3.5rem }

.header__menu-icon{ cursor:pointer;height:1.5rem;width:1.5rem }

.header__logo-img{ display:inline-block;height:3.125rem }

.header__login-btn-wrapper{ display:none }

.header__login-btn{ border:.0625rem solid #aa1f30;cursor:pointer;font-size:.75rem }

@keyframes hourglass-spin{0{-webkit-transform:rotate(0);transform:rotate(0)}
to{-webkit-transform:rotate(1turn);transform:rotate(1turn)}
}

@keyframes slideUp{0{-webkit-transform:translateY(100%);transform:translateY(100%)}
to{-webkit-transform:translateY(0);transform:translateY(0)}
}